#!/bin/sh
#
# zprune - Destructive snapshot pruning coordinator for Zelta
#
# zprune validates retention policy and executes destructive ZFS operations
# based on zelta prune output.
#
# WARNING: This tool performs DESTRUCTIVE operations. Use with caution.
#
# Design philosophy: zprune is a thin shell wrapper around zelta prune.
# It enforces safety controls: local-only, explicit policy, confirmation.

ZPRUNE_VERSION="zprune 0.1.0"

# Default retention values (same as zelta)
DEFAULT_KEEP_SNAP_NUM=100
DEFAULT_KEEP_SNAP_DAYS=90

# Usage and help
zprune_usage() {
	exec >&2
	cat << 'EOF'
usage: zprune [OPTIONS] source target [target2 ...]

Destructively prune snapshots from source that exist on target(s).

SAFETY: Pruning requires explicit policy or --prune-policy flag.
        Without these, zprune reports only (same as 'zelta prune').

Options:
  --prune-policy=POLICY   Pruning strategy:
                          - trim (default): Keep N snapshots + M days
                          - force-trim: Hard age-based deletion
                          - thin: Smart GFS thinning
                          - space: Space-based with pattern detection
                          - name: Name-based pruning (see --prune-name)
  --prune-name=NAME       Snapshot name pattern for name-based pruning:
                          - zfsnap: zfsnap_YYYY-MM-DD_HH:MM:SS pattern
                          - truenas: auto-YYYY-MM-DD_HH-MM-SS pattern
                          - sanoid: autosnap_YYYY-MM-DD_HH:MM:SS pattern
                          - Custom: any pattern string to match
  -f, --force             Do not prompt for confirmation
  -r, --recursive         Destroy recursively (pass -r to zfs destroy)
  -n, --dry-run           Show what would be destroyed without doing it
  -v, --verbose           Increase verbosity
  -q, --quiet             Suppress non-error output

Retention Options (for trim/force-trim policies):
  --keep-snap-num=N       Minimum snapshots to keep (default: 100)
  --keep-snap-days=N      Minimum age in days (default: 90)

Other Options (passed to zelta prune):
  --no-ranges             Output individual snapshots
  -X, --exclude=PATTERN   Exclude datasets matching pattern
  -d, --depth=LEVELS      Limit recursion depth

Safety:
  - source MUST be local (no user@host: prefix)
  - Requires explicit --prune-policy or retention options
  - Prompts for confirmation unless -f is used
  - Never uses 'zfs destroy -R' (protects clones)

Examples:
  # Review what would be pruned (safe, no changes)
  zprune tank/data backup:tank/backups/data

  # Use default retention policy (100 snaps, 90 days)
  zprune --prune-policy=trim tank/data backup:tank/backups/data

  # Force destroy without confirmation
  zprune --prune-policy=trim -f tank/data backup:tank/backups/data

  # Explicit retention policy
  zprune --keep-snap-num=50 --keep-snap-days=30 tank/data backup:tank/backups/data

  # Multiple targets - snapshot must exist on ALL targets
  zprune --prune-policy=trim tank/data backup:tank/data dr:tank/data

  # Name-based pruning for zfsnap snapshots
  zprune --prune-policy=name --prune-name=zfsnap tank/data backup:tank/data

For complete documentation: zelta help prune
EOF
	exit 1
}

zprune_version() {
	echo "$ZPRUNE_VERSION"
	exit 0
}

# Error output
error() {
	echo "zprune: $1" >&2
}

# Check if operand is local (no SSH)
is_local_endpoint() {
	case "$1" in
		*@*:*) return 1 ;;
		*) return 0 ;;
	esac
}

# Validate that source is a local ZFS dataset
validate_zfs_dataset() {
	_dataset="$1"
	if ! zfs list -H -oname "$_dataset" >/dev/null 2>&1; then
		error "not a valid ZFS dataset: $_dataset"
		return 1
	fi
	return 0
}

# Get snapshot name pattern for name-based pruning
# Returns the pattern string for matching snapshot names
get_name_pattern() {
	_name="$1"
	case "$_name" in
		zfsnap)
			# zfsnap pattern: zfsnap_YYYY-MM-DD_HH:MM:SS
			echo "zfsnap_*"
			;;
		truenas|TrueNAS|truenas-auto)
			# TrueNAS auto snapshots: auto-YYYY-MM-DD_HH-MM-SS
			echo "auto-*"
			;;
		sanoid)
			# Sanoid pattern: autosnap_YYYY-MM-DD_HH:MM:SS or hourly-*, daily-*, etc.
			echo "autosnap_*,hourly-*,daily-*,weekly-*,monthly-*"
			;;
		*)
			# Custom pattern - return as-is
			echo "$_name"
			;;
	esac
}

# Parse arguments
parse_args() {
	ZPRUNE_FORCE=""
	ZPRUNE_RECURSIVE=""
	ZPRUNE_DRYRUN=""
	ZPRUNE_VERBOSE=""
	ZPRUNE_QUIET=""
	ZPRUNE_POLICY=""
	ZPRUNE_NAME=""
	ZELTA_PRUNE_ARGS=""
	ZPRUNE_SOURCE=""
	ZPRUNE_TARGETS=""
	EXPLICIT_RETENTION=""

	while [ $# -gt 0 ]; do
		case "$1" in
			-h|--help)
				zprune_usage
				;;
			-V|--version)
				zprune_version
				;;
			-f|--force)
				ZPRUNE_FORCE="1"
				shift
				;;
			-r|--recursive)
				ZPRUNE_RECURSIVE="1"
				shift
				;;
			-n|--dry-run)
				ZPRUNE_DRYRUN="1"
				shift
				;;
			-v|--verbose)
				ZPRUNE_VERBOSE="1"
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS -v"
				shift
				;;
			-q|--quiet)
				ZPRUNE_QUIET="1"
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS -q"
				shift
				;;
			--prune-policy=*)
				ZPRUNE_POLICY="${1#*=}"
				shift
				;;
		--prune-policy)
			ZPRUNE_POLICY="$2"
			shift 2
			;;
		--prune-name=*)
			ZPRUNE_NAME="${1#*=}"
			shift
			;;
		--prune-name)
			ZPRUNE_NAME="$2"
			shift 2
			;;
		--keep-snap-num=*)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1"
				EXPLICIT_RETENTION="1"
				shift
				;;
			--keep-snap-num)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1 $2"
				EXPLICIT_RETENTION="1"
				shift 2
				;;
			--keep-snap-days=*)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1"
				EXPLICIT_RETENTION="1"
				shift
				;;
			--keep-snap-days)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1 $2"
				EXPLICIT_RETENTION="1"
				shift 2
				;;
			--no-ranges)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1"
				shift
				;;
			-X|--exclude|-d|--depth)
				# Options that take separate arguments
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1 $2"
				shift 2
				;;
			-X=*|--exclude=*|-d=*|--depth=*)
				ZELTA_PRUNE_ARGS="$ZELTA_PRUNE_ARGS $1"
				shift
				;;
			--)
				shift
				break
				;;
			-*)
				error "unknown option: $1"
				exit 1
				;;
			*)
				break
				;;
		esac
	done

	# Remaining arguments are operands
	if [ $# -lt 2 ]; then
		error "source and at least one target operand required"
		zprune_usage
	fi

	ZPRUNE_SOURCE="$1"
	shift
	ZPRUNE_TARGETS="$@"

	# Validate source is local
	if ! is_local_endpoint "$ZPRUNE_SOURCE"; then
		error "source must be local (SSH destruction is not permitted)"
		error "source: $ZPRUNE_SOURCE"
		exit 1
	fi

	# Validate source is a ZFS dataset
	if ! validate_zfs_dataset "$ZPRUNE_SOURCE"; then
		exit 1
	fi
}

# Check for clones that would be affected
# Returns 0 if safe, 1 if clones found
check_clones() {
	_dataset="$1"
	
	# Get list of snapshots that would be pruned
	_clone_list=$(zfs list -H -t snapshot -o name,clones -r "$_dataset" 2>/dev/null | \
		awk -F'\t' '$2 != "" {print $1 ":" $2}')
	
	if [ -n "$_clone_list" ]; then
		return 1
	fi
	return 0
}

# Report clones that block pruning
report_clones() {
	_dataset="$1"
	
	if [ -z "$ZPRUNE_QUIET" ]; then
		echo ""
		echo "ERROR: Cannot prune - clones detected:"
		zfs list -H -t snapshot -o name,clones -r "$_dataset" 2>/dev/null | \
			awk -F'\t' '$2 != "" {print "  " $1 " -> " $2}'
		echo ""
		echo "To proceed, promote the clone(s):"
		zfs list -H -t snapshot -o clones -r "$_dataset" 2>/dev/null | \
			awk -F'\t' '$1 != "" {print "  zfs promote " $1}' | sort -u
	fi
}

# Run zelta prune for a single target
# Outputs snapshot list (one per line)
run_zelta_prune() {
	_target="$1"
	
	# Build command
	_cmd="zelta prune"
	
	# Add policy-specific options
	case "$ZPRUNE_POLICY" in
		trim|"")
			# Default trim - use count + days (either explicit or defaults)
			if [ -z "$EXPLICIT_RETENTION" ]; then
				# Use defaults explicitly
				_cmd="$_cmd --keep-snap-num=$DEFAULT_KEEP_SNAP_NUM --keep-snap-days=$DEFAULT_KEEP_SNAP_DAYS"
			fi
			;;
		force-trim)
			# Hard age-based only
			if [ -z "$EXPLICIT_RETENTION" ]; then
				_cmd="$_cmd --keep-snap-days=$DEFAULT_KEEP_SNAP_DAYS"
			fi
			;;
		name)
			# Name-based pruning
			if [ -z "$ZPRUNE_NAME" ]; then
				error "--prune-policy=name requires --prune-name"
				exit 1
			fi
			_pattern=$(get_name_pattern "$ZPRUNE_NAME")
			if [ -n "$ZPRUNE_VERBOSE" ] && [ -z "$ZPRUNE_QUIET" ]; then
				echo "Using name pattern: $_pattern" >&2
			fi
			# Pass pattern to zelta prune via -X to exclude non-matching snapshots
			# This is inverted logic - we want to ONLY prune matching names
			# For MVP, we'll filter output after getting results
			if [ -z "$EXPLICIT_RETENTION" ]; then
				_cmd="$_cmd --keep-snap-num=$DEFAULT_KEEP_SNAP_NUM --keep-snap-days=$DEFAULT_KEEP_SNAP_DAYS"
			fi
			;;
		thin|space)
			# These strategies require enhanced zelta prune support
			# For MVP, fall back to basic trim with a warning
			if [ -z "$ZPRUNE_QUIET" ]; then
				echo "warning: '$ZPRUNE_POLICY' strategy not yet implemented, using trim" >&2
			fi
			if [ -z "$EXPLICIT_RETENTION" ]; then
				_cmd="$_cmd --keep-snap-num=$DEFAULT_KEEP_SNAP_NUM --keep-snap-days=$DEFAULT_KEEP_SNAP_DAYS"
			fi
			;;
		*)
			error "unknown prune policy: $ZPRUNE_POLICY"
			exit 1
			;;
	esac
	
	# Add user-specified args
	if [ -n "$ZELTA_PRUNE_ARGS" ]; then
		_cmd="$_cmd $ZELTA_PRUNE_ARGS"
	fi
	
	# Add source and target
	_cmd="$_cmd '$ZPRUNE_SOURCE' '$_target'"
	
	if [ -n "$ZPRUNE_VERBOSE" ] && [ -z "$ZPRUNE_QUIET" ]; then
		echo "Running: $_cmd" >&2
	fi
	
	eval "$_cmd"
}

# Determine if we have explicit policy for destruction
has_explicit_policy() {
	# Explicit policy if:
	# 1. --prune-policy flag was used (any value), OR
	# 2. Explicit retention options were provided
	if [ -n "$ZPRUNE_POLICY" ] || [ -n "$EXPLICIT_RETENTION" ]; then
		return 0
	fi
	return 1
}

# Count snapshots in output
count_snapshots() {
	_output="$1"
	echo "$_output" | grep -c '@' 2>/dev/null || echo "0"
}

# Confirm destruction with user
confirm_destruction() {
	_count="$1"
	
	if [ -z "$ZPRUNE_QUIET" ]; then
		echo ""
		echo "WARNING: This will PERMANENTLY DESTROY $_count snapshot range(s)."
		echo ""
		printf "Type 'destroy' to confirm: "
	fi

	# Read from /dev/tty to ensure we get user input even if stdin is piped
	read _confirm < /dev/tty
	if [ "$_confirm" != "destroy" ]; then
		if [ -z "$ZPRUNE_QUIET" ]; then
			echo "Aborted."
		fi
		exit 1
	fi
}

# Destroy snapshots from list
destroy_snapshots() {
	_snapshots="$1"
	_destroy_opts=""

	if [ -n "$ZPRUNE_RECURSIVE" ]; then
		_destroy_opts="$_destroy_opts -r"
	fi
	if [ -n "$ZPRUNE_VERBOSE" ]; then
		_destroy_opts="$_destroy_opts -v"
	fi

	_failed=0

	IFS='
'
	for _snap in $_snapshots; do
		# Skip empty lines
		[ -z "$_snap" ] && continue

		_destroy_cmd="zfs destroy$_destroy_opts '$_snap'"

		if [ -n "$ZPRUNE_DRYRUN" ]; then
			echo "[DRY-RUN] $_destroy_cmd"
		else
			if [ -n "$ZPRUNE_VERBOSE" ] && [ -z "$ZPRUNE_QUIET" ]; then
				echo "Destroying: $_snap"
			fi
			if ! eval "$_destroy_cmd"; then
				error "failed to destroy: $_snap"
				_failed=1
			fi
		fi
	done
	unset IFS

	return $_failed
}

# Filter snapshots by name pattern
# Only keep snapshots matching the specified pattern(s)
filter_by_name() {
	_snapshots="$1"
	_pattern="$2"
	
	# Convert comma-separated patterns to grep-friendly format
	_grep_pattern=$(echo "$_pattern" | sed 's/,/|/g' | sed 's/\*/.*/g')
	
	IFS='
'
	_filtered=""
	for _snap in $_snapshots; do
		[ -z "$_snap" ] && continue
		# Extract just the snapshot name (after @)
		_snapname=$(echo "$_snap" | sed 's/.*@/@/')
		if echo "$_snapname" | grep -Eq "$_grep_pattern"; then
			_filtered="$_filtered
$_snap"
		fi
	done
	unset IFS
	
	echo "$_filtered" | sed '/^$/d'
}

# Process all targets and collect snapshots that exist on ALL targets
process_targets() {
	_all_snapshots=""
	_first_target="1"
	
	for _target in $ZPRUNE_TARGETS; do
		if [ -n "$ZPRUNE_VERBOSE" ] && [ -z "$ZPRUNE_QUIET" ]; then
			echo "Checking target: $_target" >&2
		fi
		
		_target_snapshots=$(run_zelta_prune "$_target" 2>&1)
		_target_status=$?
		
		if [ $_target_status -ne 0 ]; then
			error "zelta prune failed for target $_target"
			echo "$_target_snapshots" >&2
			return 1
		fi
		
		if [ -n "$_first_target" ]; then
			# First target - use all its snapshots as base
			_all_snapshots="$_target_snapshots"
			_first_target=""
		else
			# Subsequent targets - intersect with existing
			# Only keep snapshots that appear in BOTH lists
			_common=""
			IFS='
'
			for _snap in $_all_snapshots; do
				[ -z "$_snap" ] && continue
				if echo "$_target_snapshots" | grep -Fxq "$_snap" 2>/dev/null; then
					_common="$_common
$_snap"
				fi
			done
			unset IFS
			_all_snapshots="$_common"
		fi
	done
	
	echo "$_all_snapshots"
	return 0
}

# Main
main() {
	parse_args "$@"
	
	# Check for clones before proceeding
	if ! check_clones "$ZPRUNE_SOURCE"; then
		report_clones "$ZPRUNE_SOURCE"
		exit 1
	fi
	
	# Process all targets and get intersection of prunable snapshots
	_snapshots=$(process_targets)
	_status=$?
	
	# Apply name-based filtering if using name policy
	if [ "$ZPRUNE_POLICY" = "name" ] && [ -n "$ZPRUNE_NAME" ]; then
		_pattern=$(get_name_pattern "$ZPRUNE_NAME")
		_snapshots=$(filter_by_name "$_snapshots" "$_pattern")
	fi
	
	if [ $_status -ne 0 ]; then
		exit $_status
	fi
	
	# Count snapshots
	_count=$(count_snapshots "$_snapshots")
	
	if [ "$_count" -eq 0 ]; then
		if [ -z "$ZPRUNE_QUIET" ]; then
			echo "No snapshots to prune."
		fi
		exit 0
	fi
	
	# Determine if we can proceed with destruction
	if has_explicit_policy; then
		# We have explicit policy - can destroy
		if [ -n "$ZPRUNE_VERBOSE" ] && [ -z "$ZPRUNE_QUIET" ]; then
			if [ -n "$ZPRUNE_POLICY" ]; then
				echo "Policy: $ZPRUNE_POLICY"
			else
				echo "Policy: explicit retention"
			fi
		fi
		
		if [ -n "$ZPRUNE_DRYRUN" ]; then
			if [ -z "$ZPRUNE_QUIET" ]; then
				echo ""
				echo "Dry-run mode - would destroy:"
				echo ""
			fi
			echo "$_snapshots"
			destroy_snapshots "$_snapshots"
		elif [ -z "$ZPRUNE_FORCE" ]; then
			# Show snapshots and confirm
			echo "$_snapshots"
			confirm_destruction "$_count"
			destroy_snapshots "$_snapshots"
		else
			# Force mode - destroy without confirmation
			destroy_snapshots "$_snapshots"
		fi
		exit $?
	else
		# No explicit policy - report only mode
		echo "$_snapshots"
		if [ -z "$ZPRUNE_QUIET" ]; then
			echo ""
		echo "NOTICE: No explicit retention policy specified."
		echo "        To destroy these snapshots, specify:"
		echo "        - A policy: --prune-policy=trim (or force-trim, thin, space, name)"
		echo "        - Explicit retention: --keep-snap-num=N --keep-snap-days=N"
		echo "        - Name-based: --prune-policy=name --prune-name=PATTERN"
		echo ""
		fi
		exit 0
	fi
}

main "$@"
