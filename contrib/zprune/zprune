#!/bin/sh
#
# zprune - destructive snapshot pruning wrapper for Zelta
#
# zelta prune selects snapshots. zprune adds the destructive prompt and runs
# zfs destroy against the exact candidates emitted by zelta prune.

ZPRUNE_VERSION="zprune 0.2.0"

zprune_usage() {
	exec >&2
	cat << 'EOF'
usage: zprune [OPTIONS] source target

Destructively prune source snapshots selected by zelta prune.

zprune passes normal Zelta options through to `zelta prune`. The only
zprune-specific destructive option is:

  -f, --force      Destroy without asking for confirmation

Other local options:

  -h, --help       Show this help
  -V, --version    Show version

Safety:

  - remote sources are destroyed through ZELTA_REMOTE_COMMAND
  - candidates are selected by zelta prune using ZELTA_* defaults/options
  - zfs destroy -nv previews candidates before destruction
  - confirmation requires typing: destroy
  - zfs destroy -R is never used

Examples:

  zprune tank/data backup:tank/data
  zprune --keep-snap-num=60 --keep-snap-time=14days tank/data backup:tank/data
  zprune --depth=1 --exclude='*/tmp' -f tank/data backup:tank/data

For candidate reporting without destruction, use: zelta prune
EOF
	exit 1
}

zprune_version() {
	echo "$ZPRUNE_VERSION"
	exit 0
}

error() {
	echo "zprune: $1" >&2
}

is_local_endpoint() {
	case "$1" in
		*@*:*|*:*) return 1 ;;
		*) return 0 ;;
	esac
}

get_source_remote() {
	case "$1" in
		*@*:*) ;;
		*:*) ;;
		*) return ;;
	esac
	_remote=$1
	_remote=${_remote%%:*}
	[ "$_remote" = "localhost" ] && return
	printf '%s¥n' "$_remote"
}

append_prune_arg() {
	if [ -z "$ZPRUNE_PRUNE_ARGS" ]; then
		ZPRUNE_PRUNE_ARGS=$1
	else
		ZPRUNE_PRUNE_ARGS=$ZPRUNE_PRUNE_ARGS$(printf '¥034')$1
	fi
}

parse_args() {
	ZPRUNE_FORCE=""
	ZPRUNE_SOURCE_LOCAL=""
	ZPRUNE_SOURCE_REMOTE=""
	ZPRUNE_SOURCE=""
	ZPRUNE_PRUNE_ARGS=""

	while [ $# -gt 0 ]; do
		case "$1" in
			-h|--help)
				zprune_usage
				;;
			-V|--version)
				zprune_version
				;;
			-f|--force)
				ZPRUNE_FORCE=1
				shift
				continue
				;;
			--force=*)
				error "--force does not take a value"
				exit 1
				;;
		esac

		if [ -z "$ZPRUNE_SOURCE" ]; then
			case "$1" in
				--log-level|--log-mode|--depth|-d|--exclude|-X|--include|--keep-snap-num|--keep-snap-time|--prune-snap-num|--prune-snap-time|--prune-grid|--prune-synced|--prune-size|--prune-policy|--prune-name)
					append_prune_arg "$1"
					shift
					[ $# -gt 0 ] || { error "missing argument after option"; exit 1; }
					append_prune_arg "$1"
					shift
					continue
					;;
				--)
					append_prune_arg "$1"
					shift
					[ $# -gt 0 ] || break
					ZPRUNE_SOURCE=$1
					;;
				-*)
					append_prune_arg "$1"
					shift
					continue
					;;
				*)
					ZPRUNE_SOURCE=$1
					;;
			esac
		fi

		append_prune_arg "$1"
		shift
	done

	if [ -z "$ZPRUNE_SOURCE" ]; then
		error "source and target operands required"
		zprune_usage
	fi

	if is_local_endpoint "$ZPRUNE_SOURCE"; then
		ZPRUNE_SOURCE_LOCAL=1
	else
		ZPRUNE_SOURCE_REMOTE=$(get_source_remote "$ZPRUNE_SOURCE")
	fi

}

run_zelta_prune() {
	_sep=$(printf '¥034')
	_old_ifs=$IFS
	IFS=$_sep
	set -f
	# shellcheck disable=SC2086
	set -- $ZPRUNE_PRUNE_ARGS
	set +f
	IFS=$_old_ifs
	zelta prune "$@"
}

count_candidates() {
	awk 'index($0, "@") { n++ } END { print n + 0 }'
}

validate_local_candidates() {
	_candidates=$1
	_remote=""
	_invalid=""

	IFS='
'
	for _candidate in $_candidates; do
		[ -n "$_candidate" ] || continue
		case "$_candidate" in
			*"'"*)
				_invalid=$_invalid$(printf '¥n%s' "$_candidate")
				;;
			*@*:*|*:*@*)
				_remote=$_remote$(printf '¥n%s' "$_candidate")
				;;
			*@*)
				;;
			*)
				_invalid=$_invalid$(printf '¥n%s' "$_candidate")
				;;
		esac
	done
	unset IFS

	if [ -n "$_remote" ]; then
		error "refusing unexpected remote snapshot candidates:"
		printf '%s¥n' "$_remote" >&2
		return 1
	fi

	if [ -n "$_invalid" ]; then
		error "refusing unexpected prune output:"
		printf '%s¥n' "$_invalid" >&2
		return 1
	fi

	return 0
}

run_zfs_destroy() {
	_flags=$1
	_candidate=$2

	if [ -n "$ZPRUNE_SOURCE_REMOTE" ]; then
		: ${ZELTA_REMOTE_COMMAND:=ssh}
		_cmd="$ZELTA_REMOTE_COMMAND $ZPRUNE_SOURCE_REMOTE zfs destroy $_flags '$_candidate'"
		eval "$_cmd"
	else
		zfs destroy $_flags "$_candidate"
	fi
}

preview_candidates() {
	_candidates=$1
	_failed=0

	IFS='
'
	for _candidate in $_candidates; do
		[ -n "$_candidate" ] || continue
		case "$_candidate" in
			*@*) ;;
			*) continue ;;
		esac

		printf '%s¥n' "$_candidate"
		if ! run_zfs_destroy "-nv" "$_candidate"; then
			error "preview failed: $_candidate"
			_failed=1
		fi
	done
	unset IFS

	return $_failed
}

confirm_destruction() {
	echo ""
	echo "WARNING: This will permanently destroy the previewed snapshot candidate(s)."
	printf '%s' "Type 'destroy' to confirm: "
	read _confirm < /dev/tty

	if [ "$_confirm" != "destroy" ]; then
		echo "Aborted."
		exit 1
	fi
}

destroy_candidates() {
	_candidates=$1
	_failed=0

	IFS='
'
	for _candidate in $_candidates; do
		[ -n "$_candidate" ] || continue
		case "$_candidate" in
			*@*) ;;
			*) continue ;;
		esac
		if ! run_zfs_destroy "" "$_candidate"; then
			error "failed to destroy: $_candidate"
			_failed=1
		fi
	done
	unset IFS

	return $_failed
}

main() {
	parse_args "$@"

	_candidates=$(run_zelta_prune)
	_status=$?
	if [ $_status -ne 0 ]; then
		exit $_status
	fi

	_count=$(printf '%s¥n' "$_candidates" | count_candidates)
	if [ "$_count" -eq 0 ]; then
		echo "No snapshots to prune."
		exit 0
	fi

	if [ -n "$ZPRUNE_SOURCE_REMOTE" ]; then
		error "remote source; destruction will run through ${ZELTA_REMOTE_COMMAND:-ssh}: $ZPRUNE_SOURCE_REMOTE"
	fi

	if ! validate_local_candidates "$_candidates"; then
		error "destroy aborted"
		exit 1
	fi

	if ! preview_candidates "$_candidates"; then
		error "destroy aborted"
		exit 1
	fi

	if [ -z "$ZPRUNE_FORCE" ]; then
		confirm_destruction
	fi

	destroy_candidates "$_candidates"
}

main "$@"
