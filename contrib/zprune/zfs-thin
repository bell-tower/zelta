#!/usr/bin/env python3
"""
zfs-thin - Print ZFS snapshots not kept by a simple GFS policy.

This tool is intentionally non-destructive. It shells out to:

	zfs list -Hrptsnap -oname,creation,used DATASET

and prints snapshot names selected for pruning. Use --keep to print the
snapshots retained by the policy instead.
"""

import argparse
import calendar
import subprocess
import sys
from dataclasses import dataclass, field
from datetime import datetime, timedelta


KEEP_DAYS = 30
KEEP_SNAPS = 30
WEEK_MONTHS = 3
MONTH_MONTHS = 12


@dataclass
class Snapshot:
	name: str
	created: int
	used: int
	idx: int = 0
	keep_reasons: set[str] = field(default_factory=set)


def parse_size(value: str) -> int:
	if value == "-":
		return 0
	try:
		return int(value)
	except ValueError:
		return 0


def month_delta(dt: datetime, months: int) -> datetime:
	year = dt.year + (dt.month - 1 + months) // 12
	month = (dt.month - 1 + months) % 12 + 1
	day = min(dt.day, calendar.monthrange(year, month)[1])
	return dt.replace(year=year, month=month, day=day)


def start_of_day(dt: datetime) -> datetime:
	return dt.replace(hour=0, minute=0, second=0, microsecond=0)


def start_of_week(dt: datetime) -> datetime:
	return start_of_day(dt) - timedelta(days=dt.weekday())


def start_of_month(dt: datetime) -> datetime:
	return dt.replace(day=1, hour=0, minute=0, second=0, microsecond=0)


def start_of_year(dt: datetime) -> datetime:
	return dt.replace(month=1, day=1, hour=0, minute=0, second=0, microsecond=0)


def load_snapshots(dataset: str) -> list[Snapshot]:
	cmd = ["zfs", "list", "-Hrptsnap", "-oname,creation,used", dataset]
	try:
		proc = subprocess.run(cmd, check=True, text=True, capture_output=True)
	except FileNotFoundError:
		print("zfs-thin: zfs command not found", file=sys.stderr)
		raise SystemExit(127)
	except subprocess.CalledProcessError as err:
		if err.stderr:
			print(err.stderr, end="", file=sys.stderr)
		raise SystemExit(err.returncode)

	snapshots = []
	for line in proc.stdout.splitlines():
		parts = line.split(None, 2)
		if len(parts) != 3:
			print(f"zfs-thin: skipping unparsable line: {line}", file=sys.stderr)
			continue
		try:
			created = int(parts[1])
		except ValueError:
			print(f"zfs-thin: skipping snapshot with invalid creation time: {line}", file=sys.stderr)
			continue
		snapshots.append(Snapshot(parts[0], created, parse_size(parts[2])))

	snapshots = sorted(snapshots, key=lambda snap: (snap.name.split("@", 1)[0], snap.created, snap.name))
	prev_dataset = None
	idx = 0
	for snap in snapshots:
		dataset_name = snap.name.split("@", 1)[0]
		if dataset_name != prev_dataset:
			prev_dataset = dataset_name
			idx = 0
		idx += 1
		snap.idx = idx

	return sorted(snapshots, key=lambda snap: (snap.created, snap.name))


def snapshot_range_name(start: Snapshot, end: Snapshot) -> str:
	if start.name == end.name:
		return start.name
	return f"{start.name}%{end.name.split('@', 1)[1]}"


def print_snapshots(snapshots: list[Snapshot], compress_ranges: bool) -> None:
	if not compress_ranges:
		for snap in snapshots:
			print(snap.name)
		return

	by_dataset = {}
	for snap in snapshots:
		dataset_name = snap.name.split("@", 1)[0]
		by_dataset.setdefault(dataset_name, []).append(snap)

	for dataset_name in sorted(by_dataset):
		range_start = None
		range_end = None
		prev_idx = None
		for snap in sorted(by_dataset[dataset_name], key=lambda item: item.idx):
			if range_start is None:
				range_start = snap
				range_end = snap
				prev_idx = snap.idx
				continue

			if snap.idx == prev_idx + 1:
				range_end = snap
				prev_idx = snap.idx
				continue

			print(snapshot_range_name(range_start, range_end))
			range_start = snap
			range_end = snap
			prev_idx = snap.idx

		if range_start is not None:
			print(snapshot_range_name(range_start, range_end))


def mark_first_nonzero_after(snapshots: list[Snapshot], start: int, end: int | None, reason: str) -> None:
	for snap in snapshots:
		if snap.created < start:
			continue
		if end is not None and snap.created >= end:
			break
		if snap.used > 0:
			snap.keep_reasons.add(reason)
			return


def mark_policy(snapshots: list[Snapshot], now: datetime) -> None:
	if not snapshots:
		return

	snapshots[0].keep_reasons.add("earliest")

	cutoff = int((start_of_day(now) - timedelta(days=KEEP_DAYS - 1)).timestamp())
	for snap in snapshots:
		if snap.created >= cutoff:
			snap.keep_reasons.add("recent-day")

	for snap in snapshots[-KEEP_SNAPS:]:
		snap.keep_reasons.add("recent-snap")

	week_start = start_of_week(now)
	week_stop = month_delta(now, -WEEK_MONTHS)
	while week_start >= week_stop:
		start = int(week_start.timestamp())
		end = int((week_start + timedelta(days=7)).timestamp())
		mark_first_nonzero_after(snapshots, start, end, "weekly")
		week_start -= timedelta(days=7)

	month_start = start_of_month(now)
	month_stop = month_delta(month_start, -MONTH_MONTHS + 1)
	while month_start >= month_stop:
		start = int(month_start.timestamp())
		end = int(month_delta(month_start, 1).timestamp())
		mark_first_nonzero_after(snapshots, start, end, "monthly")
		month_start = month_delta(month_start, -1)

	earliest = datetime.fromtimestamp(snapshots[0].created)
	year_start = start_of_year(now)
	year_stop = start_of_year(earliest)
	while year_start >= year_stop:
		start = int(year_start.timestamp())
		end = int(year_start.replace(year=year_start.year + 1).timestamp())
		mark_first_nonzero_after(snapshots, start, end, "yearly")
		year_start = year_start.replace(year=year_start.year - 1)


def parse_args() -> argparse.Namespace:
	parser = argparse.ArgumentParser(
		prog="zfs-thin",
		description="Print ZFS snapshots not kept by a simple GFS thinning policy.",
	)
	parser.add_argument("dataset", help="ZFS dataset or dataset tree root")
	parser.add_argument(
		"--no-ranges",
		action="store_true",
		help="print individual snapshots instead of consecutive ranges",
	)
	parser.add_argument(
		"-k",
		"--keep",
		action="store_true",
		help="print snapshots kept by the policy instead of prune candidates",
	)
	parser.add_argument(
		"-r",
		"--reasons",
		action="store_true",
		help="include keep reasons when used with --keep",
	)
	return parser.parse_args()


def main() -> int:
	args = parse_args()
	snapshots = load_snapshots(args.dataset)
	mark_policy(snapshots, datetime.now())

	selected = []
	for snap in snapshots:
		if args.keep == bool(snap.keep_reasons):
			selected.append(snap)

	if args.keep and args.reasons:
		for snap in selected:
			print(f"{snap.name}\t{','.join(sorted(snap.keep_reasons))}")
	else:
		print_snapshots(selected, not args.no_ranges)

	return 0


if __name__ == "__main__":
	raise SystemExit(main())
